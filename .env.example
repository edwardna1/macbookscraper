# Telegram Bot (create via @BotFather, then start a chat with your bot)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Poll interval (minutes)
POLL_INTERVAL_MINUTES=12

# Storage file path (optional)
# STORAGE_PATH=seen_products.json

# Apple Canada refurbished base URL (optional)
# APPLE_REFURB_BASE_URL=https://www.apple.com/ca/shop/refurbished/mac

# HTTP (optional)
# REQUEST_TIMEOUT=30
# RETRY_COUNT=3
